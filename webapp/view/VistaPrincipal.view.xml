<mvc:View xmlns:core="sap.ui.core" controllerName="filmotecadigital.controller.VistaPrincipal"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page2" title="{i18n>title}">
        <Toolbar id="toolbar">
            <SearchField id="searchField" width="250px" liveChange=".onSearch" placeholder="{i18n>buscar}"></SearchField>
            <Select id="selectFilterCountry" width="150px" change=".onFilterByCountry">
                <items>
                    <core:Item id="iTodos" key="" text="{i18n>pais-all}"/>
                    <core:Item id="iEspanha" key="España" text="{i18n>pais-esp}"/>
                    <core:Item id="iEEUU" key="Estados Unidos" text="{i18n>pais-eeuu}"/>
                    <core:Item id="iFrancia" key="Francia" text="{i18n>pais-fr}"/>
                    <core:Item id="iJapon" key="Japón" text="{i18n>pais-jp}"/>
                    <core:Item id="iCorea" key="Corea del Sur" text="{i18n>pais-kr}"/>
                </items>
            </Select>
            <Button id="btnOrdenar" text="{i18n>ordenarAnho}" press=".onOrdenarPorAnho"/>
            <Select id="selectLanguage" change=".onLanguageChange" width="120px">
                <items>
                    <core:Item id="es" key="en" text="EN"/>
                    <core:Item id="en" key="es" text="ES"/>
                    <core:Item id="it" key="it" text="IT"/>
                </items>
            </Select>
        </Toolbar>
        <Button id="btnCreate" text="{i18n>adpelicula}" press="onCreatePelicula"></Button>
        <Table
            id="tablaPeliculas"
            items="{peliculas>/}"
            mode="SingleSelectMaster"
            inset="false"
            selectionChange="onFilaSelect">
            <columns>
                <Column id="col1">
                    <Text id="text1" text="{i18n>nombre}"></Text>
                </Column>
                <Column id="col2">
                    <Text id="text2" text="{i18n>anho}"></Text>
                </Column>
                <Column id="col3">
                    <Text id="text3" text="{i18n>director}"></Text>
                </Column>
                <Column id="col4">
                    <Text id="text4" text="{i18n>pais}"></Text>
                </Column>
                <Column id="col5">
                    <Text id="text5"></Text>
                </Column>
            </columns>
            <items>
                <ColumnListItem type="Navigation" id="columnlistitem">
                    <cells>
                        <Text id="colNombre" text="{peliculas>Nombre}"></Text>
                        <Text id="colEstreno" text="{peliculas>AnhoEstreno}"></Text>
                        <Text id="colDirector" text="{peliculas>Director}"></Text>
                        <Text id="colPais" text="{peliculas>Pais}"></Text>
                        <Button id="btnBorrarPelicula" text="{i18n>borrar}" press="onDeletePelicula"></Button>
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </Page>
</mvc:View>